# Database
DATABASE_URL=postgresql://mtg_import:mtg_import@localhost:5434/mtg_import

# Security - generate with: openssl rand -hex 32
SECRET_KEY=

# Saleor Instance (for local development)
ALLOWED_DOMAIN_PATTERN=/.*/

# App URLs (local development)
APP_IFRAME_BASE_URL=http://localhost:3003
APP_API_BASE_URL=http://localhost:3003

# APL Storage (file for local, redis for production)
APL=file
# REDIS_URL=redis://localhost:6379

# Cron job authentication (optional)
# CRON_SECRET=

# Logging
APP_LOG_LEVEL=debug

# Currency
DEFAULT_CURRENCY=USD

# Scryfall settings
SCRYFALL_CACHE_DIR=/tmp/scryfall-cache
SCRYFALL_CACHE_MAX_AGE_HOURS=6

# Import settings
IMPORT_BATCH_SIZE=100
JOB_POLL_INTERVAL_MS=5000

# Default channels for pricing
DEFAULT_CHANNEL_SLUGS=default-channel,singles-builder
